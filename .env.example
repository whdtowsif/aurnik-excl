# ===========================================
# Aurnik - Environment Variables for Netlify
# ===========================================

# Database (Turso)
# Get these from https://turso.tech
DATABASE_URL="libsql://your-database.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# NextAuth Configuration
# NEXTAUTH_URL must be your Netlify site URL (with https://)
NEXTAUTH_URL="https://your-site.netlify.app"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# Google OAuth (Required for Google Sign-in)
# Get these from: https://console.cloud.google.com/apis/credentials
# Make sure to add your Netlify URL to Authorized redirect URIs:
# https://your-site.netlify.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ===========================================
# Optional Integrations
# ===========================================

# WhatsApp Business API (optional)
WHATSAPP_ACCESS_TOKEN="your-whatsapp-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"

# Facebook Integration (optional)
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_PAGE_ID="your-facebook-page-id"
FACEBOOK_ACCESS_TOKEN="your-facebook-access-token"

# SSLCommerz Payment Gateway (optional)
SSLCZ_STORE_ID="your-store-id"
SSLCZ_STORE_PASS="your-store-password"
